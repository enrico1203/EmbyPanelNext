FROM python:3.13-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    chromium-driver \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-scheduler.txt ./
RUN pip install --no-cache-dir -r requirements-scheduler.txt

COPY . .

EXPOSE 9092

CMD ["uvicorn", "scheduler_worker:app", "--host", "0.0.0.0", "--port", "9092"]
